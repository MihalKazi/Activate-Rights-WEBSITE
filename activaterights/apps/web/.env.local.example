# You can place this file here OR at `activaterights/.env.local` OR at the repo root
# (same folder as `activaterights/`). Next, Sanity CLI, and seed scripts load all three.
#
# Used by Next.js and Sanity CLI / Studio (see load-monorepo-env.mjs, sanity.cli.ts).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Viewer (read) token — required if the dataset is not public; server-only, never NEXT_PUBLIC_*
SANITY_API_TOKEN=
# Editor token for `npm run seed:events` / imports (create documents)
SANITY_API_WRITE_TOKEN=
SANITY_WEBHOOK_SECRET=
NEXT_PUBLIC_BASE_URL=https://activaterights.org
